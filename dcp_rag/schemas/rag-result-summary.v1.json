    "avg_score": { "type": "number", "min": 0, "max": 1, "description": "Average relevance score" }
  },
  "examples": [
    [true, 3, "auth", 0.88],
    [false, 0, "billing", 0.0],
    [true, 7, "deployment", 0.72]
  ]
}